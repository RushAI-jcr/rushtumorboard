# =============================================================================
# Rush GYN Oncology Tumor Board - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#
# For local testing with synthetic data, the defaults below work as-is
# (except Azure OpenAI credentials which you must provide).
# =============================================================================

# --- Azure OpenAI (REQUIRED) ---
# Primary model for all agents (GPT-4.1 recommended)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/

# Reasoning model for ClinicalTrials agent (o3-mini recommended, optional)
AZURE_OPENAI_DEPLOYMENT_NAME_REASONING_MODEL=o3-mini
AZURE_OPENAI_REASONING_MODEL_ENDPOINT=https://<your-resource>.openai.azure.com/

# --- Scenario ---
SCENARIO=default

# --- Clinical Data Source ---
# Options: caboodle, epic, fhir, fabric
# For local testing with synthetic CSV data, use "caboodle"
CLINICAL_NOTES_SOURCE=caboodle
CABOODLE_DATA_DIR=../infra/patient_data

# --- Bot Framework (dummy values for local testing) ---
# These are only needed for the full Bot Framework web app.
# For local agent testing, these dummy values prevent config.py from crashing.
BOT_IDS={"Orchestrator":"dummy-orch","PatientHistory":"dummy-ph","OncologicHistory":"dummy-oh","Pathology":"dummy-path","Radiology":"dummy-rad","PatientStatus":"dummy-ps","ClinicalGuidelines":"dummy-cg","ReportCreation":"dummy-rc","ClinicalTrials":"dummy-ct","MedicalResearch":"dummy-mr"}
HLS_MODEL_ENDPOINTS={}

# --- Agent Exclusions ---
# Comma-separated list of agent names to exclude.
# MedicalResearch requires GraphRAG — exclude it if you haven't deployed GraphRAG.
# EXCLUDED_AGENTS=MedicalResearch
EXCLUDED_AGENTS=

# --- GraphRAG (only needed if MedicalResearch agent is included) ---
# GRAPH_RAG_SUBSCRIPTION_KEY=
# GRAPH_RAG_ENDPOINT=

# --- Azure Monitor (optional) ---
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- FHIR (only if CLINICAL_NOTES_SOURCE=fhir) ---
# FHIR_SERVICE_ENDPOINT=

# --- Fabric (only if CLINICAL_NOTES_SOURCE=fabric) ---
# FABRIC_USER_DATA_FUNCTION_ENDPOINT=
